{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=SERVER_NAME;Database=DB_NAME;User=DB_USER;Password=DB_PASSWORD;"
  },
  "AllowedHosts": "*",
  "HttpClient": {
    "BaseAddress": "http://localhost:5151"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:3000"
  },
  "SmtpSettings": {
    "Host": "SMTP_HOST",
    "Port": "SMTP_PORT",
    "Email": "SMTP_EMAIL",
    "Password": "SMTP_PASSWORD"
  }
}
