    // Обработка поиска
    private void SearchFlights()
    {
        // форматируем дату аккуратно, учитывая nullable
        var dateText = Date.HasValue ? Date.Value.ToString("dd.MM.yyyy") : "(не указана)";
        Console.WriteLine($"Поиск: {From} → {To}, Дата: {dateText}, Пассажиры: {Passengers}");
        // Здесь будет логика поиска рейсов через API
    }
}

}
