# Copy this file to .env and fill the real secrets locally.
# Do NOT commit .env to Git.

ASPNETCORE_ENVIRONMENT=Production
MYSQL_DATABASE=ZetTechAvioDB
DB_PASSWORD=your_mysql_root_password

# ASP.NET Core configuration via nested keys
# The Docker Compose file already builds the connection string from these values.
HttpClient__BaseAddress=http://backend:5151/
Cors__AllowedOrigins=https://example.com
Urls=http://0.0.0.0:5151;https://0.0.0.0:5152
JWT_SECRET=your_jwt_secret_here
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_API_KEY=your_yookassa_api_key
YOOKASSA_RETURN_URL=https://example.com/payment-return
